---
import Base from '../../layouts/Base.astro';
import { render } from 'astro:content';
import { getPublishedEntries } from '../../lib/entries.mjs';

export async function getStaticPaths() {
  const entries = await getPublishedEntries();
  return entries.map(entry => ({
    params: { slug: entry.data.publish_id },
    props: { post: entry },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const domainLabels = {
  investment: '投资研究',
  ai: 'AI 与技术',
  beyond: '边界之外',
};
---

<Base title={`${post.data.title} - Deep Value Research`} description={post.data.summary}>
  <article class="blog-post">
    <header class="post-header">
      <p class="eyebrow">{domainLabels[post.data.domain]}</p>
      <h1 class="post-title">{post.data.title}</h1>
      <p class="post-summary">{post.data.summary}</p>
      <div class="post-meta">
        <span>{post.data.published_at.toLocaleDateString('zh-CN')}</span>
        {post.data.updated_at && <span>更新：{post.data.updated_at.toLocaleDateString('zh-CN')}</span>}
        <span>{post.data.format}</span>
        <span>{post.data.status}</span>
        {post.data.confidence && <span>confidence: {post.data.confidence}</span>}
      </div>
      {post.data.thesis && (
        <p class="thesis">{post.data.thesis}</p>
      )}
      {post.data.tags.length > 0 && (
        <div class="post-tags">
          {post.data.tags.map(tag => <span class="tag">{tag}</span>)}
        </div>
      )}
    </header>

    <div class="post-content">
      <Content />
    </div>
  </article>

  <div class="back-link">
    <a href="/blog" class="pill-btn">返回研究文章</a>
  </div>
</Base>

<style>
  .blog-post {
    padding: 72px 0 48px;
  }

  .post-header {
    display: grid;
    gap: 22px;
    margin-bottom: 64px;
    padding-bottom: 48px;
    border-bottom: 1px solid var(--line);
  }

  .eyebrow,
  .post-meta {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    color: var(--metadata-primary);
  }

  .post-title {
    max-width: 920px;
    font-size: clamp(40px, 7vw, 86px);
    font-weight: 500;
    line-height: 0.98;
    letter-spacing: 0;
  }

  .post-summary {
    max-width: 760px;
    font-size: 18px;
    line-height: 1.8;
    color: var(--text-secondary);
  }

  .post-meta,
  .post-tags {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  .thesis {
    max-width: 860px;
    padding: 18px 20px;
    border-left: 2px solid var(--accent-warm);
    background: color-mix(in srgb, var(--color-copper) 9%, var(--color-paper));
    color: var(--text-primary);
    line-height: 1.8;
  }

  .post-content {
    max-width: 880px;
    font-family: var(--font-body);
    font-size: 17px;
    line-height: 1.9;
    color: var(--text-primary);
  }

  .post-content p {
    margin-bottom: 24px;
  }

  .post-content h2 {
    margin-top: 52px;
    margin-bottom: 18px;
    font-size: 30px;
    font-weight: 500;
    line-height: 1.2;
    color: var(--text);
  }

  .post-content h3 {
    margin-top: 36px;
    margin-bottom: 14px;
    font-size: 22px;
    font-weight: 500;
    color: var(--text);
  }

  .post-content ul,
  .post-content ol {
    margin-bottom: 24px;
    padding-left: 24px;
  }

  .post-content li {
    margin-bottom: 10px;
  }

  .post-content strong {
    font-weight: 500;
    color: var(--text);
  }

  .post-content a {
    color: var(--link-primary);
    border-bottom: 1px solid currentColor;
  }

  .post-content :global(table) {
    display: table;
    width: 100%;
    max-width: 100%;
    margin: 34px 0;
    overflow: hidden;
    border: 1px solid var(--border-subtle);
    border-radius: 8px;
    border-spacing: 0;
    border-collapse: separate;
    background: color-mix(in srgb, var(--color-ink) 2.5%, var(--color-paper));
    box-shadow: 0 18px 48px rgba(0, 0, 0, 0.22);
    white-space: normal;
  }

  .post-content :global(thead) {
    background: color-mix(in srgb, var(--color-ink) 8%, var(--color-paper));
  }

  .post-content :global(tbody tr:nth-child(even)) {
    background: color-mix(in srgb, var(--color-ink) 4%, var(--color-paper));
  }

  .post-content :global(tbody tr:hover) {
    background: color-mix(in srgb, var(--color-copper) 10%, var(--color-paper));
  }

  .post-content :global(th),
  .post-content :global(td) {
    padding: 14px 16px;
    border-right: 1px solid var(--border-subtle);
    border-bottom: 1px solid var(--border-subtle);
    text-align: left;
    vertical-align: top;
    word-break: normal;
    overflow-wrap: anywhere;
  }

  .post-content :global(th:last-child),
  .post-content :global(td:last-child) {
    border-right: 0;
  }

  .post-content :global(tr:last-child td) {
    border-bottom: 0;
  }

  .post-content :global(th) {
    color: var(--text);
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  .post-content :global(td) {
    color: var(--text-secondary);
  }

  .post-content blockquote {
    margin: 32px 0;
    padding-left: 24px;
    border-left: 2px solid var(--muted);
    color: var(--text-secondary);
  }

  .post-content code {
    font-family: var(--font-mono);
    font-size: 0.9em;
    background: color-mix(in srgb, var(--color-ink) 9%, var(--color-paper));
    padding: 2px 8px;
    border-radius: 4px;
  }

  .post-content pre {
    margin: 32px 0;
    padding: 24px;
    overflow-x: auto;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: color-mix(in srgb, var(--color-ink) 6%, var(--color-paper));
  }

  .post-content pre code {
    background: none;
    padding: 0;
  }

  .back-link {
    margin-top: 80px;
    padding-top: 48px;
    border-top: 1px solid var(--line);
  }

  @media (max-width: 760px) {
    .blog-post {
      padding: 52px 0 32px;
    }

    .post-header {
      margin-bottom: 44px;
      padding-bottom: 34px;
    }

    .post-content {
      font-size: 16px;
    }

    .post-content :global(th),
    .post-content :global(td) {
      padding: 12px 14px;
    }

    .post-content :global(table) {
      display: block;
      overflow-x: auto;
      white-space: nowrap;
    }
  }
</style>
