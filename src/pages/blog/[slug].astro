---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Base title={post.data.title} description={post.data.description}>
  <article>
    <header>
      <h1>{post.data.title}</h1>
      <div style="color: #666; font-size: 0.9rem; margin-bottom: 2rem;">
        {post.data.date.toLocaleDateString('zh-CN')}
        {post.data.tags && post.data.tags.length > 0 && (
          <span> · {post.data.tags.join(', ')}</span>
        )}
      </div>
    </header>
    <Content />
  </article>

  <div style="margin-top: 3rem; padding-top: 1rem; border-top: 1px solid #eee;">
    <a href="/blog">← 返回博客列表</a>
  </div>
</Base>
