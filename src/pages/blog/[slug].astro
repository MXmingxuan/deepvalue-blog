---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const sectorLabels = {
  fluorochemical: '氟化工研究',
  'ai-data-center': 'AI 数据中心研究',
  other: '其他研究',
};
---

<Base title={`${post.data.title} - Deep Value Research`} description={post.data.description || post.data.summary}>
  <article class="blog-post">
    <header class="post-header">
      <p class="eyebrow">{sectorLabels[post.data.sector]}</p>
      <h1 class="post-title">{post.data.title}</h1>
      <p class="post-summary">{post.data.summary || post.data.description}</p>
      <div class="post-meta">
        <span>{post.data.date.toLocaleDateString('zh-CN')}</span>
        {post.data.updated && <span>更新：{post.data.updated.toLocaleDateString('zh-CN')}</span>}
        <span>{post.data.research_type}</span>
        <span>{post.data.status}</span>
        {post.data.confidence && <span>confidence: {post.data.confidence}</span>}
      </div>
      {post.data.thesis && (
        <p class="thesis">{post.data.thesis}</p>
      )}
      {post.data.tags.length > 0 && (
        <div class="post-tags">
          {post.data.tags.map(tag => <span class="tag">{tag}</span>)}
        </div>
      )}
    </header>

    <div class="post-content">
      <Content />
    </div>
  </article>

  <div class="back-link">
    <a href="/blog" class="pill-btn">返回研究文章</a>
  </div>
</Base>

<style>
  .blog-post {
    padding: 72px 0 48px;
  }

  .post-header {
    display: grid;
    gap: 22px;
    margin-bottom: 64px;
    padding-bottom: 48px;
    border-bottom: 1px solid var(--line);
  }

  .eyebrow,
  .post-meta {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    color: var(--muted);
  }

  .post-title {
    max-width: 920px;
    font-size: clamp(40px, 7vw, 86px);
    font-weight: 500;
    line-height: 0.98;
    letter-spacing: 0;
  }

  .post-summary {
    max-width: 760px;
    font-size: 18px;
    line-height: 1.8;
    color: rgba(246, 243, 236, 0.74);
  }

  .post-meta,
  .post-tags {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  .thesis {
    max-width: 860px;
    padding: 18px 20px;
    border-left: 2px solid var(--accent-warm);
    background: rgba(216, 181, 109, 0.08);
    color: rgba(246, 243, 236, 0.88);
    line-height: 1.8;
  }

  .post-content {
    max-width: 880px;
    font-family: var(--font-body);
    font-size: 17px;
    line-height: 1.9;
    color: rgba(246, 243, 236, 0.86);
  }

  .post-content p {
    margin-bottom: 24px;
  }

  .post-content h2 {
    margin-top: 52px;
    margin-bottom: 18px;
    font-size: 30px;
    font-weight: 500;
    line-height: 1.2;
    color: var(--text);
  }

  .post-content h3 {
    margin-top: 36px;
    margin-bottom: 14px;
    font-size: 22px;
    font-weight: 500;
    color: var(--text);
  }

  .post-content ul,
  .post-content ol {
    margin-bottom: 24px;
    padding-left: 24px;
  }

  .post-content li {
    margin-bottom: 10px;
  }

  .post-content strong {
    font-weight: 500;
    color: var(--text);
  }

  .post-content a {
    border-bottom: 1px solid var(--muted);
  }

  .post-content blockquote {
    margin: 32px 0;
    padding-left: 24px;
    border-left: 2px solid var(--muted);
    color: var(--muted);
  }

  .post-content code {
    font-family: var(--font-mono);
    font-size: 0.9em;
    background: rgba(245, 243, 238, 0.1);
    padding: 2px 8px;
    border-radius: 4px;
  }

  .post-content pre {
    margin: 32px 0;
    padding: 24px;
    overflow-x: auto;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: rgba(245, 243, 238, 0.08);
  }

  .post-content pre code {
    background: none;
    padding: 0;
  }

  .back-link {
    margin-top: 80px;
    padding-top: 48px;
    border-top: 1px solid var(--line);
  }

  @media (max-width: 760px) {
    .blog-post {
      padding: 52px 0 32px;
    }

    .post-header {
      margin-bottom: 44px;
      padding-bottom: 34px;
    }

    .post-content {
      font-size: 16px;
    }
  }
</style>
