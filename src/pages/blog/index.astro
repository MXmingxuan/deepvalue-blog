---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const sortedPosts = posts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const allTags = [...new Set(posts.flatMap(post => post.data.tags || []))].sort();
---

<Base title="博客 - 宋明璇" description="投资分析、AI 与分析思维">
  <section class="page-header">
    <p class="label">// BLOG</p>
    <h1>博客</h1>
  </section>

  <div class="layout">
    <aside class="sidebar">
      <p class="sidebar-label">标签</p>
      <div class="tag-list">
        <button data-tag="all" class="tag-btn active">全部</button>
        {allTags.map(tag => (
          <button data-tag={tag} class="tag-btn">{tag}</button>
        ))}
      </div>
    </aside>

    <main class="content">
      <ul class="post-list" id="post-list">
        {sortedPosts.map(post => (
          <li class="post-item" data-tags={JSON.stringify(post.data.tags || [])}>
            <a href={`/blog/${post.id}`} class="post-title">{post.data.title}</a>
            <div class="post-meta">
              <span class="post-date">{post.data.date.toLocaleDateString('zh-CN')}</span>
              {post.data.tags && post.data.tags.length > 0 && (
                <div class="post-tags">
                  {post.data.tags.slice(0, 3).map(tag => (
                    <span class="tag">{tag}</span>
                  ))}
                </div>
              )}
            </div>
          </li>
        ))}
      </ul>
      <p id="no-posts" class="no-posts">// 无相关文章</p>
    </main>
  </div>
</Base>

<script>
  const buttons = document.querySelectorAll('.tag-btn');
  const posts = document.querySelectorAll('.post-item');
  const noPosts = document.getElementById('no-posts');

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const tag = btn.getAttribute('data-tag');

      buttons.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');

      let visibleCount = 0;
      posts.forEach(post => {
        const tags = JSON.parse(post.getAttribute('data-tags') || '[]');
        if (tag === 'all' || tags.includes(tag)) {
          (post as HTMLElement).style.display = '';
          visibleCount++;
        } else {
          (post as HTMLElement).style.display = 'none';
        }
      });

      if (noPosts) {
        noPosts.style.display = visibleCount === 0 ? 'block' : 'none';
      }
    });
  });
</script>

<style>
  .page-header {
    padding: 48px 0 32px;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 32px;
  }

  .label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-accent);
    margin-bottom: 12px;
  }

  .page-header h1 {
    font-size: 1.75rem;
  }

  .layout {
    display: flex;
    gap: 48px;
    align-items: flex-start;
  }

  .sidebar {
    min-width: 80px;
    position: sticky;
    top: 24px;
  }

  .sidebar-label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-dim);
    margin-bottom: 12px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .tag-list {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .tag-btn {
    background: none;
    border: none;
    padding: 5px 0;
    font-size: 14px;
    color: var(--color-text-dim);
    cursor: pointer;
    text-align: left;
    transition: color 0.15s;
    font-family: var(--font-mono);
  }

  .tag-btn:hover {
    color: var(--color-primary);
  }

  .tag-btn.active {
    color: var(--color-accent);
  }

  .content {
    flex: 1;
    min-width: 0;
  }

  .post-list {
    list-style: none;
  }

  .post-item {
    padding: 16px 0;
    border-bottom: 1px solid var(--color-border);
  }

  .post-item:first-child {
    padding-top: 0;
  }

  .post-title {
    display: block;
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-primary);
    margin-bottom: 8px;
    transition: color 0.15s;
  }

  .post-title:hover {
    color: var(--color-accent);
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  .post-date {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-dim);
  }

  .post-tags {
    display: flex;
    gap: 6px;
  }

  .tag {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-dim);
    background: var(--color-surface);
    padding: 2px 6px;
    border-radius: 2px;
  }

  .no-posts {
    display: none;
    color: var(--color-text-dim);
    font-family: var(--font-mono);
    padding: 24px 0;
  }

  @media (max-width: 768px) {
    .layout {
      flex-direction: column;
      gap: 24px;
    }

    .sidebar {
      position: static;
      order: 2;
    }

    .tag-list {
      flex-direction: row;
      flex-wrap: wrap;
      gap: 6px;
    }

    .tag-btn {
      background: var(--color-surface);
      padding: 4px 10px;
      border-radius: 2px;
    }

    .tag-btn.active {
      background: var(--color-accent);
      color: var(--color-bg);
    }

    .content {
      order: 1;
    }
  }
</style>
