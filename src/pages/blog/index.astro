---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const sortedPosts = posts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// Extract all unique tags
const allTags = [...new Set(posts.flatMap(post => post.data.tags || []))].sort();
---

<Base title="博客 - 宋明璇" description="投资分析、AI 与分析思维">
  <div style="display: flex; gap: 2rem;">
    <!-- Sidebar with tags -->
    <aside style="min-width: 150px;">
      <h3 style="font-size: 1rem; color: #666; margin-bottom: 0.5rem;">标签筛选</h3>
      <div id="tag-filter" style="display: flex; flex-direction: column; gap: 0.5rem;">
        <button
          data-tag="all"
          class="tag-btn active"
          style="background: #0070f3; color: white; border: none; padding: 0.4rem 0.8rem; border-radius: 4px; cursor: pointer; text-align: left; font-size: 0.9rem;"
        >
          全部
        </button>
        {allTags.map(tag => (
          <button
            data-tag={tag}
            class="tag-btn"
            style="background: #f5f5f5; color: #333; border: 1px solid #ddd; padding: 0.4rem 0.8rem; border-radius: 4px; cursor: pointer; text-align: left; font-size: 0.9rem;"
          >
            {tag}
          </button>
        ))}
      </div>
    </aside>

    <!-- Main content -->
    <main style="flex: 1;">
      <h1>博客</h1>
      <ul id="post-list" style="list-style: none; padding: 0;">
        {sortedPosts.map(post => (
          <li class="post-item" data-tags={JSON.stringify(post.data.tags || [])}>
            <a href={`/blog/${post.id}`}>{post.data.title}</a>
            <span style="color: #666; font-size: 0.9rem;">
              — {post.data.date.toLocaleDateString('zh-CN')}
            </span>
            {post.data.tags && post.data.tags.length > 0 && (
              <div style="margin-top: 0.3rem;">
                {post.data.tags.map(tag => (
                  <span style="display: inline-block; background: #e8f0fe; color: #0070f3; padding: 0.1rem 0.4rem; border-radius: 3px; font-size: 0.75rem; margin-right: 0.3rem;">
                    {tag}
                  </span>
                ))}
              </div>
            )}
          </li>
        ))}
      </ul>
      <p id="no-posts" style="display: none; color: #666;">暂无相关文章</p>
    </main>
  </div>
</Base>

<script>
  const buttons = document.querySelectorAll('.tag-btn');
  const posts = document.querySelectorAll('.post-item');
  const noPosts = document.getElementById('no-posts');

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const tag = btn.getAttribute('data-tag');

      // Update button styles
      buttons.forEach(b => {
        b.classList.remove('active');
        b.style.background = '#f5f5f5';
        b.style.color = '#333';
      });
      btn.classList.add('active');
      btn.style.background = '#0070f3';
      btn.style.color = 'white';

      // Filter posts
      let visibleCount = 0;
      posts.forEach(post => {
        const tags = JSON.parse(post.getAttribute('data-tags') || '[]');
        if (tag === 'all' || tags.includes(tag)) {
          (post as HTMLElement).style.display = 'block';
          visibleCount++;
        } else {
          (post as HTMLElement).style.display = 'none';
        }
      });

      noPosts!.style.display = visibleCount === 0 ? 'block' : 'none';
    });
  });
</script>

<style>
  .tag-btn:hover {
    background: #e0e0e0 !important;
  }
  .tag-btn.active:hover {
    background: #005dd3 !important;
  }
  .post-item {
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid #eee;
  }
</style>
