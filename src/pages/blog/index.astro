---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const sortedPosts = posts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const sectorLabels = {
  chemical: '化工',
  'ai-infrastructure': 'AI 基础设施',
  'shipping-shipbuilding': '航运与船舶',
  other: '其他',
};

const allSectors = [...new Set(sortedPosts.map(post => post.data.sector))];
---

<Base title="研究文章 - Deep Value Research" description="产业研究文章归档">
  <section class="page-header">
    <p class="eyebrow">RESEARCH NOTES</p>
    <h1 class="page-title">研究文章</h1>
    <p class="page-intro">按专题、类型和时间沉淀研究记录。每篇文章都尽量保留核心假设、证据边界和后续证伪条件。</p>
  </section>

  <div class="layout">
    <aside class="sidebar">
      <p class="sidebar-label">专题</p>
      <div class="filter-list">
        <button data-sector="all" class="filter-btn active">全部</button>
        {allSectors.map(sector => (
          <button data-sector={sector} class="filter-btn">{sectorLabels[sector]}</button>
        ))}
      </div>
    </aside>

    <section class="content" aria-label="文章列表">
      <ul class="post-list" id="post-list">
        {sortedPosts.map(post => (
          <li class="post-item" data-sector={post.data.sector}>
            <a href={`/blog/${post.id}`} class="post-link">
              <span class="post-title">{post.data.title}</span>
              <span class="post-arrow">打开</span>
            </a>
            <p class="post-summary">{post.data.summary || post.data.description}</p>
            <div class="post-meta">
              <span>{post.data.date.toLocaleDateString('zh-CN')}</span>
              <span>{sectorLabels[post.data.sector]}</span>
              <span>{post.data.research_type}</span>
              {post.data.tags.slice(0, 3).map(tag => <span class="tag">{tag}</span>)}
            </div>
          </li>
        ))}
      </ul>
      <p id="no-posts" class="no-posts">没有匹配的研究文章。</p>
    </section>
  </div>
</Base>

<script>
  const buttons = document.querySelectorAll('.filter-btn');
  const posts = document.querySelectorAll('.post-item');
  const noPosts = document.getElementById('no-posts');

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const sector = btn.getAttribute('data-sector');
      buttons.forEach((button) => button.classList.remove('active'));
      btn.classList.add('active');

      let visibleCount = 0;
      posts.forEach((post) => {
        const shouldShow = sector === 'all' || post.getAttribute('data-sector') === sector;
        (post as HTMLElement).style.display = shouldShow ? '' : 'none';
        if (shouldShow) visibleCount++;
      });

      if (noPosts) {
        noPosts.style.display = visibleCount === 0 ? 'block' : 'none';
      }
    });
  });
</script>

<style>
  .page-header {
    padding: 72px 0 52px;
    border-bottom: 1px solid var(--line);
    margin-bottom: 48px;
  }

  .eyebrow,
  .sidebar-label,
  .post-meta,
  .no-posts {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    color: var(--muted);
  }

  .page-title {
    margin-top: 16px;
    font-size: clamp(48px, 8vw, 92px);
    font-weight: 500;
    line-height: 0.96;
    letter-spacing: 0;
  }

  .page-intro {
    max-width: 680px;
    margin-top: 24px;
    font-size: 18px;
    line-height: 1.8;
    color: rgba(246, 243, 236, 0.72);
  }

  .layout {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: 64px;
    align-items: flex-start;
  }

  .sidebar {
    position: sticky;
    top: 32px;
  }

  .sidebar-label {
    margin-bottom: 18px;
  }

  .filter-list {
    display: grid;
    gap: 8px;
  }

  .filter-btn {
    width: 100%;
    padding: 10px 0;
    border: 0;
    border-bottom: 1px solid transparent;
    background: transparent;
    color: var(--muted);
    cursor: pointer;
    font-family: var(--font-mono);
    font-size: 12px;
    text-align: left;
  }

  .filter-btn:hover,
  .filter-btn.active {
    color: var(--text);
    border-bottom-color: var(--text);
  }

  .post-list {
    list-style: none;
    border-top: 1px solid var(--line);
  }

  .post-item {
    display: grid;
    gap: 14px;
    padding: 28px 0;
    border-bottom: 1px solid var(--line);
  }

  .post-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }

  .post-title {
    font-size: clamp(24px, 4vw, 44px);
    line-height: 1.12;
  }

  .post-arrow {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--muted);
  }

  .post-summary {
    max-width: 760px;
    color: rgba(246, 243, 236, 0.72);
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  .no-posts {
    display: none;
    padding: 32px 0;
  }

  @media (max-width: 780px) {
    .layout {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .sidebar {
      position: static;
    }

    .filter-list {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    .filter-btn {
      width: auto;
      min-height: 36px;
      padding: 8px 12px;
      border: 1px solid var(--line);
      border-radius: 999px;
    }

    .filter-btn.active {
      background: var(--text);
      color: var(--ink);
      border-color: var(--text);
    }
  }
</style>
