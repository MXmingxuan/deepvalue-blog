---
import Base from '../../layouts/Base.astro';
import EntryList from '../../components/EntryList.astro';
import { getPublishedEntries } from '../../lib/entries.mjs';

const sortedPosts = await getPublishedEntries({ format: 'article' });

const domainLabels = {
  investment: '投资研究',
  ai: 'AI 与技术',
  beyond: '边界之外',
};

const allDomains = [...new Set(sortedPosts.map(post => post.data.domain))];
---

<Base title="研究文章 - Deep Value Research" description="Deep Value Research 已发布研究文章索引">
  <header class="article-index-header">
    <div class="article-index-kicker">
      <p>RESEARCH ARTICLES</p>
      <span>DURABLE CONCLUSIONS</span>
    </div>
    <div class="article-index-copy">
      <h1>研究文章</h1>
      <p>按领域、专题和时间沉淀可复用的研究结论，尽量保留核心假设、证据边界和后续证伪条件。</p>
    </div>
  </header>

  <div class="article-index-layout" data-entry-filter-scope>
    <aside class="domain-filter" aria-label="按领域筛选文章">
      <p>DOMAIN FILTER</p>
      <div>
        <button type="button" class="is-active" data-domain-filter="all" aria-pressed="true">
          <span>00</span>全部
        </button>
        {allDomains.map((domain, index) => (
          <button type="button" data-domain-filter={domain} aria-pressed="false">
            <span>{String(index + 1).padStart(2, '0')}</span>{domainLabels[domain]}
          </button>
        ))}
      </div>
    </aside>

    <section class="article-index-list" aria-labelledby="article-list-title">
      <header>
        <div>
          <p>ARTICLE INDEX</p>
          <h2 id="article-list-title">全部文章</h2>
        </div>
        <span>{String(sortedPosts.length).padStart(2, '0')} PUBLISHED</span>
      </header>

      <EntryList
        entries={sortedPosts}
        emptyText="暂时没有已发布的研究文章。"
      />
    </section>
  </div>
</Base>

<style>
  .article-index-header {
    display: grid;
    grid-template-columns: minmax(9rem, 0.25fr) minmax(0, 1fr);
    gap: clamp(2rem, 6vw, 6.5rem);
    padding: clamp(2rem, 5vw, 4.75rem) 0 var(--space-6);
    border-bottom: 1px solid var(--color-ink);
  }

  .article-index-kicker {
    display: grid;
    align-content: space-between;
    min-height: 9rem;
    color: var(--metadata-primary);
    font-family: var(--font-data);
    font-size: var(--caption);
    letter-spacing: 0.1em;
    line-height: 1.6;
  }

  .article-index-kicker p,
  .article-index-copy h1,
  .article-index-copy p {
    margin: 0;
  }

  .article-index-kicker span {
    color: var(--link-primary);
  }

  .article-index-copy {
    display: grid;
    gap: var(--space-3);
  }

  .article-index-copy h1 {
    font-size: var(--step-4);
    font-weight: var(--weight-medium);
    letter-spacing: -0.035em;
    line-height: 1.05;
  }

  .article-index-copy p {
    max-width: 46rem;
    color: var(--text-secondary);
    font-size: var(--step-1);
    line-height: 1.75;
  }

  .article-index-layout {
    display: grid;
    grid-template-columns: minmax(9rem, 0.25fr) minmax(0, 1fr);
    gap: clamp(2rem, 6vw, 6.5rem);
    padding-top: var(--space-6);
  }

  .domain-filter {
    position: sticky;
    top: calc(var(--header-height) + 2rem);
    align-self: start;
  }

  .domain-filter > p {
    margin: 0 0 var(--space-3);
    color: var(--metadata-primary);
    font-family: var(--font-data);
    font-size: var(--caption);
    letter-spacing: 0.1em;
  }

  .domain-filter > div {
    display: grid;
    border-top: 1px solid var(--border-subtle);
  }

  .domain-filter button {
    display: grid;
    grid-template-columns: 2rem 1fr;
    gap: var(--space-2);
    align-items: center;
    min-height: 44px;
    padding: 0.65rem 0;
    color: var(--metadata-primary);
    border: 0;
    border-bottom: 1px solid var(--border-subtle);
    border-radius: 0;
    background: transparent;
    cursor: pointer;
    font-family: var(--font-data);
    font-size: var(--caption);
    text-align: left;
  }

  .domain-filter button span {
    color: var(--link-primary);
  }

  .domain-filter button:hover,
  .domain-filter button.is-active {
    color: var(--text-primary);
  }

  .domain-filter button.is-active {
    box-shadow: inset 3px 0 0 var(--color-copper-text);
    padding-left: var(--space-2);
  }

  .article-index-list {
    min-width: 0;
  }

  .article-index-list > header {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: var(--space-3);
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--color-ink);
  }

  .article-index-list > header p,
  .article-index-list > header h2,
  .article-index-list > header span {
    margin: 0;
  }

  .article-index-list > header p,
  .article-index-list > header span {
    color: var(--metadata-primary);
    font-family: var(--font-data);
    font-size: var(--caption);
    letter-spacing: 0.09em;
  }

  .article-index-list > header h2 {
    margin-top: var(--space-1);
    font-size: var(--step-3);
    font-weight: var(--weight-medium);
    line-height: 1.15;
  }

  @media (max-width: 760px) {
    .article-index-header,
    .article-index-layout {
      grid-template-columns: 1fr;
      gap: var(--space-3);
    }

    .article-index-header {
      padding-top: var(--space-4);
    }

    .article-index-kicker {
      display: flex;
      min-height: 0;
      justify-content: space-between;
    }

    .article-index-copy h1 {
      font-size: var(--step-3);
    }

    .article-index-layout {
      padding-top: var(--space-5);
    }

    .domain-filter {
      position: static;
    }

    .domain-filter > div {
      display: flex;
      flex-wrap: wrap;
    }

    .domain-filter button {
      display: inline-flex;
      width: auto;
      padding: 0.65rem 0.85rem;
      border-right: 1px solid var(--border-subtle);
      text-align: center;
    }

    .domain-filter button.is-active {
      color: var(--text-inverse);
      background: var(--color-ink);
      box-shadow: none;
    }

    .domain-filter button.is-active span {
      color: var(--color-copper);
    }
  }
</style>
