---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects');
---

<Base title="项目 - 宋明璇" description="投资分析工具与 AI 应用项目">
  <section class="page-header">
    <h1>项目</h1>
    <p class="page-desc">一些实践中的想法与工具</p>
  </section>

  <div class="project-list">
    {projects.map(project => (
      <article class="project-item">
        <header>
          <h2 class="project-title">{project.data.title}</h2>
          {project.data.status && (
            <span class="status">{project.data.status}</span>
          )}
        </header>
        <p class="project-desc">{project.data.description}</p>
        {project.data.tech && project.data.tech.length > 0 && (
          <div class="project-tech">
            {project.data.tech.map(tech => (
              <span class="tech-tag">{tech}</span>
            ))}
          </div>
        )}
        {project.data.link && (
          <a href={project.data.link} target="_blank" class="project-link">
            查看项目 →
          </a>
        )}
      </article>
    ))}
  </div>
</Base>

<style>
  .page-header {
    padding: 64px 0 48px;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 48px;
  }

  .page-header h1 {
    font-size: 2.5rem;
    margin-bottom: 12px;
  }

  .page-desc {
    color: var(--color-text-light);
    font-size: 1rem;
  }

  .project-list {
    display: grid;
    gap: 0;
  }

  .project-item {
    padding: 32px 0;
    border-bottom: 1px solid var(--color-border);
  }

  .project-item:first-child {
    padding-top: 0;
  }

  .project-item header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 12px;
  }

  .project-title {
    font-size: 1.375rem;
    font-weight: 600;
    color: var(--color-primary);
  }

  .status {
    font-size: 0.75rem;
    color: var(--color-text-light);
    background: #f3f4f6;
    padding: 4px 10px;
    border-radius: 4px;
  }

  .project-desc {
    font-size: 1rem;
    color: var(--color-text-light);
    line-height: 1.7;
    margin-bottom: 16px;
  }

  .project-tech {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 16px;
  }

  .tech-tag {
    font-size: 0.75rem;
    color: var(--color-text-light);
    background: #f3f4f6;
    padding: 4px 10px;
    border-radius: 4px;
  }

  .project-link {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-accent);
  }

  .project-link:hover {
    text-decoration: underline;
  }
</style>
