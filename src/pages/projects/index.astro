---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects');
---

<Base title="项目 - 宋明璇" description="投资分析工具与 AI 应用项目">
  <section class="page-header">
    <p class="label">// PROJECTS</p>
    <h1>项目</h1>
  </section>

  <div class="project-list">
    {projects.map(project => (
      <article class="project-item">
        <header>
          <span class="project-title">{project.data.title}</span>
          {project.data.status && (
            <span class="status">{project.data.status}</span>
          )}
        </header>
        <p class="project-desc">{project.data.description}</p>
        {project.data.tech && project.data.tech.length > 0 && (
          <div class="project-tech">
            {project.data.tech.map(tech => (
              <span class="tech-tag">{tech}</span>
            ))}
          </div>
        )}
        {project.data.link && (
          <a href={project.data.link} target="_blank" class="project-link">
            → 查看项目
          </a>
        )}
      </article>
    ))}
  </div>
</Base>

<style>
  .page-header {
    padding: 48px 0 32px;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 32px;
  }

  .label {
    font-family: var(--font-mono);
    font-size: 1rem;
    color: var(--color-accent);
    margin-bottom: 12px;
  }

  .page-header h1 {
    font-size: 1.75rem;
  }

  .project-list {
    display: grid;
    gap: 0;
  }

  .project-item {
    padding: 24px 0;
    border-bottom: 1px solid var(--color-border);
  }

  .project-item:first-child {
    padding-top: 0;
  }

  .project-item header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 10px;
  }

  .project-title {
    font-size: 1.0625rem;
    font-weight: 500;
    color: var(--color-primary);
  }

  .status {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    color: var(--color-bg);
    background: var(--color-accent);
    padding: 2px 6px;
    border-radius: 2px;
  }

  .project-desc {
    font-size: 0.875rem;
    color: var(--color-text-dim);
    line-height: 1.6;
    margin-bottom: 12px;
  }

  .project-tech {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-bottom: 12px;
  }

  .tech-tag {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--color-text-dim);
    background: var(--color-surface);
    padding: 3px 8px;
    border-radius: 2px;
  }

  .project-link {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--color-accent);
  }

  .project-link:hover {
    color: var(--color-accent-dim);
  }
</style>
