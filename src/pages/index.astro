---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const recentPosts = posts
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const projects = await getCollection('projects');
---

<Base title="Deep Value" description="AI & Trading">
  <section class="hero">
    <p class="label">// ABOUT</p>
    <h1 class="name">宋明璇</h1>
    <p class="tagline">AI & Trading</p>
    <p class="bio">
      产业投资背景，目前专注于 AI × 交易，<br>
      探索用 AI 重构研究与决策过程。
    </p>
  </section>

  <section class="section">
    <p class="label">// PROJECTS</p>
    <div class="list">
      {projects.map(project => (
        <article class="item">
          <div class="item-header">
            <span class="item-title">{project.data.title}</span>
            {project.data.status && (
              <span class="status">{project.data.status}</span>
            )}
          </div>
          <p class="item-desc">{project.data.description}</p>
          {project.data.tech && (
            <div class="tags">
              {project.data.tech.slice(0, 4).map(t => <span class="tag">{t}</span>)}
            </div>
          )}
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <p class="label">// RECENT POSTS</p>
    <div class="list">
      {recentPosts.map(post => (
        <article class="item">
          <a href={`/blog/${post.id}`} class="item-title link">{post.data.title}</a>
          <div class="item-meta">
            {post.data.tags && post.data.tags.slice(0, 2).map(tag => (
              <span class="tag">{tag}</span>
            ))}
            <span class="date">{post.data.date.toLocaleDateString('zh-CN')}</span>
          </div>
        </article>
      ))}
    </div>
    <a href="/blog" class="more">→ 查看全部文章</a>
  </section>
</Base>

<style>
  .hero {
    padding: 64px 0 72px;
  }

  .label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-accent);
    margin-bottom: 16px;
    letter-spacing: 0.05em;
  }

  .name {
    font-size: 2.5rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin-bottom: 8px;
  }

  .tagline {
    font-family: var(--font-mono);
    font-size: 1rem;
    color: var(--color-accent);
    margin-bottom: 20px;
  }

  .bio {
    font-size: 1.0625rem;
    color: var(--color-text);
    line-height: 1.9;
    letter-spacing: 0.01em;
  }

  .section {
    padding: 64px 0;
  }

  .list {
    display: grid;
    gap: 0;
  }

  .item {
    padding: 24px 0;
    border-bottom: 1px solid var(--color-border);
    transition: border-color 0.15s ease;
  }

  .item:first-child {
    padding-top: 0;
  }

  .item:hover {
    border-color: #3a3a3a;
  }

  .item:hover .item-title:not(.link) {
    color: #ffffff;
  }

  .item-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 8px;
  }

  .item-title {
    font-size: 1.125rem;
    font-weight: 500;
    color: var(--color-primary);
  }

  .item-title.link {
    display: block;
    position: relative;
    transition: color 0.15s ease;
  }

  .item-title.link::before {
    content: '→';
    position: absolute;
    left: -18px;
    opacity: 0;
    color: var(--color-accent);
    transition: opacity 0.15s ease;
  }

  .item-title.link:hover {
    color: var(--color-accent);
  }

  .item-title.link:hover::before {
    opacity: 1;
  }

  .status {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    color: var(--color-bg);
    background: var(--color-accent);
    padding: 2px 6px;
    border-radius: 2px;
  }

  .item-desc {
    font-size: 1rem;
    color: var(--color-text-dim);
    line-height: 1.6;
    margin-bottom: 10px;
  }

  .item-meta {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }

  .tag {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--color-text-dim);
    background: var(--color-surface);
    padding: 3px 8px;
    border-radius: 2px;
    transition: background-color 0.15s ease;
  }

  .tag:hover {
    background: #252525;
  }

  .date {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-dim);
  }

  .more {
    display: inline-block;
    margin-top: 24px;
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--color-accent);
  }

  .more:hover {
    color: var(--color-accent-dim);
  }

  @media (max-width: 768px) {
    .hero {
      padding: 40px 0 48px;
    }

    .name {
      font-size: 2rem;
    }
  }
</style>
