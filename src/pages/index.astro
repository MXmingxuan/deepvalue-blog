---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const recentPosts = posts
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 5);

const projects = await getCollection('projects');
---

<Base title="宋明璇" description="AI & Trading">
  <section class="hero">
    <h1 class="name">宋明璇</h1>
    <p class="tagline">AI & Trading</p>
    <p class="bio">
      产业投资背景，<br>
      目前专注于 AI × 交易，<br>
      探索用 AI 重构研究与决策过程。
    </p>
  </section>

  <!-- Greek key divider -->
  <div class="greek-divider">
    <svg viewBox="0 0 100 20" xmlns="http://www.w3.org/2000/svg">
      <path d="M0,10 L10,10 L10,5 L20,5 L20,10 L30,10 L30,5 L40,5 L40,10 L50,10 L50,5 L60,5 L60,10 L70,10 L70,5 L80,5 L80,10 L90,10 L90,5 L100,5" fill="none" stroke="currentColor" stroke-width="2"/>
    </svg>
  </div>

  <section class="recent-projects">
    <h2 class="section-title">项目</h2>
    <div class="project-grid">
      {projects.slice(0, 3).map(project => (
        <div class="project-card">
          <h3 class="project-title">{project.data.title}</h3>
          <p class="project-description">{project.data.description}</p>
        </div>
      ))}
    </div>
    <a href="/projects" class="view-more">查看全部项目 →</a>
  </section>

  <!-- Greek key divider -->
  <div class="greek-divider">
    <svg viewBox="0 0 100 20" xmlns="http://www.w3.org/2000/svg">
      <path d="M0,10 L10,10 L10,5 L20,5 L20,10 L30,10 L30,5 L40,5 L40,10 L50,10 L50,5 L60,5 L60,10 L70,10 L70,5 L80,5 L80,10 L90,10 L90,5 L100,5" fill="none" stroke="currentColor" stroke-width="2"/>
    </svg>
  </div>

  <section class="recent-posts">
    <h2 class="section-title">最新文章</h2>
    <ul class="post-list">
      {recentPosts.map(post => (
        <li class="post-item">
          <a href={`/blog/${post.id}`} class="post-title">{post.data.title}</a>
          <span class="post-date">{post.data.date.toLocaleDateString('zh-CN')}</span>
        </li>
      ))}
    </ul>
    <a href="/blog" class="view-more">查看更多文章 →</a>
  </section>

  <!--
  如需添加图片，使用以下方式：
  1. 将图片放入 src/assets/ 目录
  2. 使用 Image 组件：

  ---
  import { Image } from 'astro:assets';
  import myImage from '../assets/my-image.jpg';
  ---

  <div class="hero-image">
    <Image src={myImage} alt="描述" width={800} />
  </div>
  -->
</Base>

<style>
  .hero {
    text-align: center;
    padding: 3rem 0 4rem;
  }

  .name {
    font-size: 2.8rem;
    color: var(--color-primary);
    margin-bottom: 0.3rem;
    font-weight: 700;
  }

  .tagline {
    font-size: 1.2rem;
    color: var(--color-accent);
    margin-bottom: 2rem;
    font-weight: 500;
  }

  .bio {
    max-width: 500px;
    margin: 0 auto;
    color: var(--color-text);
    line-height: 1.9;
    font-size: 1.05rem;
  }

  .greek-divider {
    display: flex;
    justify-content: center;
    margin: 2.5rem 0;
    color: var(--color-gold);
  }

  .greek-divider svg {
    width: 120px;
    height: 24px;
  }

  .recent-projects {
    margin-top: 2rem;
  }

  .section-title {
    font-size: 1.2rem;
    color: var(--color-primary);
    margin-bottom: 1.5rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--color-gold);
    display: inline-block;
  }

  .project-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .project-card {
    background: white;
    border-radius: 8px;
    padding: 1.2rem;
    box-shadow: 0 2px 8px rgba(0,0,0,0.06);
    border: 1px solid var(--color-border);
  }

  .project-card .project-title {
    font-size: 1rem;
    color: var(--color-primary);
    margin-bottom: 0.5rem;
    font-weight: 600;
  }

  .project-card .project-description {
    font-size: 0.9rem;
    color: #666;
    margin: 0;
    line-height: 1.5;
  }

  .recent-posts {
    margin-top: 2rem;
  }

  .post-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .post-item {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 1rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .post-title {
    color: var(--color-primary);
    font-weight: 500;
  }

  .post-title:hover {
    color: var(--color-accent);
  }

  .post-date {
    color: #999;
    font-size: 0.85rem;
    white-space: nowrap;
    margin-left: 1rem;
  }

  .view-more {
    display: inline-block;
    margin-top: 1.5rem;
    color: var(--color-accent);
    font-weight: 500;
  }

  .view-more:hover {
    text-decoration: underline;
  }

  /* For hero images */
  .hero-image {
    margin: 2rem 0;
    text-align: center;
  }

  .hero-image img {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
  }

  @media (max-width: 768px) {
    .name {
      font-size: 2rem;
    }

    .post-item {
      flex-direction: column;
      gap: 0.3rem;
    }

    .post-date {
      margin-left: 0;
    }
  }
</style>
