---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const recentPosts = posts
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const projects = await getCollection('projects');
---

<Base title="宋明璇" description="AI & Trading">
  <section class="hero">
    <h1 class="name">宋明璇</h1>
    <p class="tagline">AI & Trading</p>
    <p class="bio">
      产业投资背景，目前专注于 AI × 交易，<br>
      探索用 AI 重构研究与决策过程。
    </p>
  </section>

  <section class="section">
    <h2 class="section-label">项目</h2>
    <div class="project-list">
      {projects.map(project => (
        <article class="project-item">
          <h3 class="project-title">{project.data.title}</h3>
          <p class="project-desc">{project.data.description}</p>
          {project.data.tech && (
            <div class="project-tags">
              {project.data.tech.slice(0, 3).map(t => <span class="tag">{t}</span>)}
            </div>
          )}
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <h2 class="section-label">最近文章</h2>
    <div class="post-list">
      {recentPosts.map(post => (
        <article class="post-item">
          <a href={`/blog/${post.id}`} class="post-title">{post.data.title}</a>
          <div class="post-meta">
            {post.data.tags && post.data.tags.slice(0, 2).map(tag => (
              <span class="tag">{tag}</span>
            ))}
            <span class="post-date">{post.data.date.toLocaleDateString('zh-CN')}</span>
          </div>
        </article>
      ))}
    </div>
    <a href="/blog" class="more">查看全部文章 →</a>
  </section>
</Base>

<style>
  .hero {
    padding: 80px 0 96px;
  }

  .name {
    font-size: 3.5rem;
    font-weight: 800;
    letter-spacing: -0.03em;
    margin-bottom: 16px;
    color: var(--color-primary);
  }

  .tagline {
    font-size: 1.5rem;
    color: var(--color-accent);
    font-weight: 500;
    margin-bottom: 24px;
  }

  .bio {
    font-size: 1.125rem;
    color: var(--color-text);
    line-height: 1.8;
    max-width: 540px;
  }

  .section {
    padding: 64px 0;
    border-top: 1px solid var(--color-border);
  }

  .section-label {
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-light);
    margin-bottom: 32px;
  }

  .project-list {
    display: grid;
    gap: 0;
  }

  .project-item {
    padding: 28px 0;
    border-bottom: 1px solid var(--color-border);
  }

  .project-item:first-child {
    padding-top: 0;
  }

  .project-title {
    font-size: 1.375rem;
    font-weight: 600;
    color: var(--color-primary);
    margin-bottom: 8px;
  }

  .project-desc {
    font-size: 1rem;
    color: var(--color-text-light);
    line-height: 1.6;
    margin-bottom: 12px;
  }

  .project-tags {
    display: flex;
    gap: 8px;
  }

  .tag {
    font-size: 0.75rem;
    color: var(--color-text-light);
    background: #f3f4f6;
    padding: 4px 10px;
    border-radius: 4px;
  }

  .post-list {
    display: grid;
    gap: 0;
  }

  .post-item {
    padding: 24px 0;
    border-bottom: 1px solid var(--color-border);
  }

  .post-item:first-child {
    padding-top: 0;
  }

  .post-title {
    display: block;
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-primary);
    margin-bottom: 10px;
    transition: color 0.2s;
  }

  .post-title:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  .post-date {
    font-size: 0.875rem;
    color: var(--color-text-light);
  }

  .more {
    display: inline-block;
    margin-top: 32px;
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-accent);
  }

  .more:hover {
    text-decoration: underline;
  }

  @media (max-width: 768px) {
    .hero {
      padding: 48px 0 64px;
    }

    .name {
      font-size: 2.5rem;
    }

    .section {
      padding: 48px 0;
    }
  }
</style>
