---
import Base from '../layouts/Base.astro';
import { getPublishedEntries } from '../lib/entries.mjs';
const publishedEntries = await getPublishedEntries();
const investmentArticles = publishedEntries.filter(
  entry => entry.data.domain === 'investment' && entry.data.format === 'article',
);
const featuredEntry = investmentArticles[0];
const recentLogs = publishedEntries.filter(entry => entry.data.format === 'log').slice(0, 3);
const aiEntries = publishedEntries.filter(entry => entry.data.domain === 'ai').slice(0, 3);
const beyondEntries = publishedEntries.filter(entry => entry.data.domain === 'beyond').slice(0, 3);
const topicLabels = {
  fluorochemicals: 'Fluorochemicals',
  energy: 'Energy',
  shipping: 'Shipping',
  'ai-infrastructure': 'AI Infrastructure',
};
const confidenceLabels = {
  low: 'Low',
  medium: 'Medium',
  high: 'High',
};
const formatDate = (date: Date) => new Intl.DateTimeFormat('en-GB', {
  day: '2-digit',
  month: 'short',
  year: 'numeric',
  timeZone: 'UTC',
}).format(date).toUpperCase();
const dateTime = (date: Date) => date.toISOString().slice(0, 10);
const featuredMeta = featuredEntry ? [
  ...featuredEntry.data.tags.slice(0, 3),
  featuredEntry.data.companies.length > 0
    ? `${featuredEntry.data.companies.join(' · ')}${
      featuredEntry.data.tickers.length > 0 ? ` · ${featuredEntry.data.tickers.join(' · ')}` : ''
    }`
    : featuredEntry.data.tickers.join(' · '),
].filter(Boolean) : [];
---
<Base
  title="Deep Value Research"
  description="Deep Value 以投资、交易与大宗商品研究为核心，同时记录 AI 应用、研究工作流与边界之外的探索。"
>
  <section class="hero" aria-labelledby="hero-title">
    <div class="hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">Investment · Trading · Commodities</p>
        <h1 id="hero-title">投资、交易与大宗商品研究</h1>
        <p class="hero-intro">
          Deep Value 以投资、交易与大宗商品研究为核心，同时记录 AI 应用、研究工作流与边界之外的探索。
        </p>
        <div class="hero-actions">
          <a class="text-link" href="/investment/">进入投资研究</a>
          <a class="text-link" href="/research-log/">查看研究日志</a>
        </div>
      </div>
      <aside class="hero-index" aria-label="研究范围">
        <div class="hero-index-row"><span>01</span><span>资源与产业</span></div>
        <div class="hero-index-row"><span>02</span><span>宏观与周期</span></div>
        <div class="hero-index-row"><span>03</span><span>市场与交易</span></div>
        <div class="hero-index-row"><span>04</span><span>AI 与研究工作流</span></div>
      </aside>
    </div>
  </section>
  <div class="paper">
    <div class="issue-bar" aria-label="出版信息">
      <span>Deep Value / Research</span>
      <span class="olive">Published work only</span>
      <span>Independent publication</span>
    </div>
    <div class="content-frame">
      <section aria-labelledby="featured-heading">
        <div class="section-label">
          <h2 id="featured-heading">FEATURED RESEARCH / 重点研究</h2>
          <span>
            {featuredEntry
              ? `Investment · ${
                topicLabels[featuredEntry.data.topic as keyof typeof topicLabels]
                  || featuredEntry.data.topic
                  || 'Research'
              }`
              : 'Published work only'}
          </span>
        </div>
        {featuredEntry ? (
          <article class="featured">
            <div class="feature-main">
              <div>
                <div class="feature-kicker">
                  <span>Published research</span>
                  <time datetime={dateTime(featuredEntry.data.published_at)}>
                    {formatDate(featuredEntry.data.published_at)}
                  </time>
                </div>
                <h3>{featuredEntry.data.title}</h3>
                {featuredEntry.data.summary && (
                  <p class="feature-summary">{featuredEntry.data.summary}</p>
                )}
                {featuredMeta.length > 0 && (
                  <div class="meta-line" aria-label="研究标签">
                    {featuredMeta.map(item => <span>{item}</span>)}
                  </div>
                )}
              </div>
              <a class="text-link feature-link" href={`/blog/${featuredEntry.data.publish_id}`}>
                阅读全文
              </a>
            </div>
            <aside class="feature-rail" aria-label="研究判断">
              <div class="rail-label">Research judgment</div>
              <div class="thesis">
                <span>Thesis</span>
                <p>{featuredEntry.data.thesis || '完整研究判断见文章正文。'}</p>
              </div>
              <div class="confidence">
                <span>Confidence</span>
                <span>
                  {featuredEntry.data.confidence
                    ? confidenceLabels[featuredEntry.data.confidence]
                    : 'Not stated'}
                </span>
              </div>
            </aside>
          </article>
        ) : (
          <div class="featured-empty">
            <p>当前没有已发布的重点研究。</p>
          </div>
        )}
      </section>
      <section class="investment-section" aria-labelledby="investment-heading">
        <div class="section-label">
          <h2 id="investment-heading">INVESTMENT RESEARCH / 投资研究</h2>
          <a href="/investment/">进入栏目</a>
        </div>
        {investmentArticles.length > 0 ? (
          <ol class="investment-list">
            {investmentArticles.map((entry, index) => (
              <li>
                <span class="entry-index">{String(index + 1).padStart(2, '0')}</span>
                <div class="entry-copy">
                  <p class="entry-meta">
                    <span>{entry.data.topic || entry.data.section || 'investment'}</span>
                    <time datetime={dateTime(entry.data.published_at)}>
                      {formatDate(entry.data.published_at)}
                    </time>
                  </p>
                  <h3>
                    <a href={`/blog/${entry.data.publish_id}`}>{entry.data.title}</a>
                  </h3>
                  {entry.data.summary && <p class="entry-summary">{entry.data.summary}</p>}
                </div>
                <a class="row-link" href={`/blog/${entry.data.publish_id}`} aria-label={`阅读全文：${entry.data.title}`}>
                  阅读全文
                </a>
              </li>
            ))}
          </ol>
        ) : (
          <div class="section-empty">
            <p>当前没有已发布的投资研究文章。</p>
          </div>
        )}
      </section>
      <div class="secondary-grid">
        <section class="desk-module" aria-labelledby="log-heading">
          <div class="module-heading">
            <span>02</span>
            <h2 id="log-heading">RESEARCH LOG / 研究日志</h2>
          </div>
          {recentLogs.length > 0 ? (
            <ol class="compact-list">
              {recentLogs.map(entry => (
                <li>
                  <time datetime={dateTime(entry.data.published_at)}>
                    {formatDate(entry.data.published_at)}
                  </time>
                  <a href={`/blog/${entry.data.publish_id}`}>{entry.data.title}</a>
                </li>
              ))}
            </ol>
          ) : (
            <div class="module-empty">
              <p>研究日志记录判断如何形成、变化与被验证。当前尚无已发布研究日志。</p>
              <span>No published research logs</span>
            </div>
          )}
          <a class="module-link" href="/research-log/">查看研究日志</a>
        </section>
        <section class="desk-module" aria-labelledby="ai-heading">
          <div class="module-heading">
            <span>03</span>
            <h2 id="ai-heading">AI &amp; TECHNOLOGY / AI 与技术</h2>
          </div>
          {aiEntries.length > 0 ? (
            <ol class="compact-list">
              {aiEntries.map(entry => (
                <li>
                  <time datetime={dateTime(entry.data.published_at)}>
                    {formatDate(entry.data.published_at)}
                  </time>
                  <a href={`/blog/${entry.data.publish_id}`}>{entry.data.title}</a>
                </li>
              ))}
            </ol>
          ) : (
            <div class="module-empty">
              <p>这里收录 AI 应用、技术观察与研究工作流。当前尚无已发布内容。</p>
              <span>No published AI entries</span>
            </div>
          )}
          <a class="module-link" href="/ai/">进入 AI 与技术</a>
        </section>
      </div>
      <section class="method" aria-labelledby="method-title">
        <div class="method-title">
          <p class="eyebrow">Editorial method</p>
          <h2 id="method-title">把判断放回证据</h2>
        </div>
        <div class="method-grid">
          <div class="method-item">
            <strong>01 / EVIDENCE</strong>
            <p>区分公司披露、行业资料、事实观察与研究者推断。</p>
          </div>
          <div class="method-item">
            <strong>02 / CONDITIONS</strong>
            <p>给出判断成立、强化、转弱与失效的条件。</p>
          </div>
          <div class="method-item">
            <strong>03 / CONTINUITY</strong>
            <p>让文章承载完整研究，让日志保留判断演化的时间线。</p>
          </div>
          <div class="method-item">
            <strong>04 / SCOPE</strong>
            <p>不以虚构条目填充版面，只展示已经发布的研究。</p>
          </div>
        </div>
      </section>
      <section class="beyond-module" aria-labelledby="beyond-heading">
        <div class="beyond-title">
          <span>04 / BEYOND THE BOUNDARY</span>
          <h2 id="beyond-heading">边界之外</h2>
        </div>
        <div class="beyond-content">
          {beyondEntries.length > 0 ? (
            <ol class="compact-list">
              {beyondEntries.map(entry => (
                <li>
                  <time datetime={dateTime(entry.data.published_at)}>
                    {formatDate(entry.data.published_at)}
                  </time>
                  <a href={`/blog/${entry.data.publish_id}`}>{entry.data.title}</a>
                </li>
              ))}
            </ol>
          ) : (
            <p>这里保留对生活、阅读与其他长期兴趣的观察。当前尚无已发布内容。</p>
          )}
          <a class="module-link" href="/beyond/">进入边界之外</a>
        </div>
      </section>
    </div>
  </div>
</Base>
<style>
  .hero {
    position: relative;
    display: grid;
    min-height: min(920px, 100svh);
    overflow: hidden;
    color: var(--text-inverse);
    background-color: var(--color-ink);
    isolation: isolate;
  }
  .hero::before {
    position: absolute;
    inset: 0;
    z-index: -3;
    content: "";
    background-image: url("/images/brand/commodities-macro-hero.png");
    background-position: center 54%;
    background-size: cover;
    transform: scale(1.015);
  }
  .hero::after {
    position: absolute;
    inset: 0;
    z-index: -2;
    content: "";
    background:
      linear-gradient(90deg, rgb(11 12 11 / 94%) 0%, rgb(11 12 11 / 74%) 34%, rgb(11 12 11 / 18%) 72%),
      linear-gradient(0deg, rgb(11 12 11 / 90%) 0%, transparent 46%, rgb(11 12 11 / 26%) 100%);
  }
  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.45fr) minmax(240px, 0.55fr);
    align-items: end;
    width: min(1440px, 100%);
    min-height: inherit;
    margin: 0 auto;
    padding: calc(var(--header-height) + 7rem) 3.2vw 4.25rem;
    animation: hero-arrive var(--duration-entrance) var(--ease-editorial) both;
  }
  .hero-copy {
    align-self: end;
    max-width: 840px;
  }
  .eyebrow {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    margin: 0;
    font-family: var(--font-data);
    font-size: var(--caption);
    letter-spacing: 0.16em;
    line-height: 1.4;
    text-transform: uppercase;
  }
  .eyebrow::before {
    width: 2.6rem;
    height: 1px;
    content: "";
    background: currentColor;
  }
  .hero .eyebrow {
    color: color-mix(in srgb, var(--color-copper) 84%, var(--color-paper));
  }
  .hero h1 {
    max-width: 10ch;
    margin: 1.15rem 0 1.5rem;
    font-size: var(--h1);
    font-weight: var(--weight-medium);
    letter-spacing: -0.035em;
    line-height: 0.98;
  }
  .hero-intro {
    max-width: 650px;
    margin: 0;
    color: color-mix(in srgb, var(--color-paper) 82%, transparent);
    font-size: var(--body-large);
    line-height: 1.85;
  }
  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-top: 2.4rem;
  }
  .text-link,
  .module-link,
  .row-link {
    font-family: var(--font-data);
    font-size: 0.73rem;
    letter-spacing: 0.08em;
  }
  .text-link {
    display: inline-flex;
    align-items: center;
    min-width: 11rem;
    min-height: 48px;
    padding: 0.7rem 0;
    border-bottom: 1px solid currentColor;
    transition: color var(--duration-fast) linear, padding var(--duration-base) var(--ease-editorial);
  }
  .text-link:hover {
    padding-left: 0.4rem;
    color: var(--color-copper);
  }
  .hero-index {
    align-self: end;
    margin-left: 3rem;
    border-top: 1px solid var(--border-subtle-inverse);
  }
  .hero-index-row {
    display: grid;
    grid-template-columns: 2.5rem 1fr;
    gap: 0.5rem;
    padding: 0.9rem 0;
    color: var(--text-inverse-muted);
    border-bottom: 1px solid var(--border-subtle-inverse);
    font-family: var(--font-data);
    font-size: var(--caption);
    line-height: 1.5;
  }
  .hero-index-row span:first-child {
    color: var(--color-copper);
  }
  .paper {
    color: var(--text-primary);
    background-color: var(--surface-primary);
    background-image: linear-gradient(
      color-mix(in srgb, var(--color-ink) 2.2%, transparent) 1px,
      transparent 1px
    );
    background-size: 100% 9px;
  }
  .issue-bar {
    display: grid;
    grid-template-columns: 1.15fr 1fr 0.8fr;
    width: min(1440px, 100%);
    min-height: 66px;
    margin: 0 auto;
    border-right: 1px solid var(--border-subtle);
    border-left: 1px solid var(--border-subtle);
  }
  .issue-bar span {
    display: flex;
    align-items: center;
    padding: 0 1.5rem;
    border-right: 1px solid var(--border-subtle);
    font-family: var(--font-data);
    font-size: var(--caption);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .issue-bar span:last-child {
    border-right: 0;
  }
  .issue-bar .olive {
    color: var(--color-olive);
  }
  .content-frame {
    width: min(1440px, 100%);
    margin: 0 auto;
    border: 1px solid var(--border-subtle);
    border-bottom: 0;
  }
  .section-label {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    min-height: 64px;
    padding: 0 1.5rem;
    border-bottom: 1px solid var(--border-subtle);
    font-family: var(--font-data);
    font-size: var(--caption);
    letter-spacing: 0.13em;
    text-transform: uppercase;
  }
  .section-label h2 {
    margin: 0;
    font: inherit;
  }
  .section-label > :last-child {
    color: var(--color-olive);
    letter-spacing: 0.04em;
  }
  .section-label a {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    transition: color var(--duration-fast) linear;
  }
  .section-label a:hover {
    color: var(--color-copper);
  }
  .featured {
    display: grid;
    grid-template-columns: minmax(0, 1.55fr) minmax(300px, 0.45fr);
    min-height: 640px;
    border-bottom: 1px solid var(--border-subtle);
  }
  .feature-main {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: clamp(2rem, 5vw, 5.5rem);
    border-right: 1px solid var(--border-subtle);
  }
  .feature-kicker,
  .meta-line,
  .rail-label,
  .confidence,
  .entry-meta,
  .entry-index,
  .module-heading,
  .module-empty span,
  .compact-list time,
  .beyond-title > span {
    font-family: var(--font-data);
    font-size: var(--caption);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .feature-kicker {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    color: var(--color-copper);
  }
  .feature-main h3 {
    max-width: 17ch;
    margin: 2.5rem 0 2rem;
    font-size: clamp(2.4rem, 5vw, 5.6rem);
    font-weight: var(--weight-medium);
    letter-spacing: -0.035em;
    line-height: 1.06;
  }
  .feature-summary {
    max-width: 690px;
    margin: 0;
    color: var(--text-secondary);
    font-size: var(--body-large);
    line-height: 1.9;
  }
  .meta-line {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem 1.2rem;
    margin-top: 3rem;
    padding-top: 1.2rem;
    color: var(--color-olive);
    border-top: 1px solid var(--border-subtle);
  }
  .feature-link {
    align-self: flex-start;
    min-width: min(100%, 15rem);
    margin-top: 2rem;
    color: var(--color-copper);
  }
  .feature-rail {
    display: grid;
    grid-template-rows: auto 1fr auto;
  }
  .rail-label {
    padding: 1.4rem 1.5rem;
    color: var(--color-olive);
    border-bottom: 1px solid var(--border-subtle);
  }
  .thesis {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 2.25rem 1.5rem;
  }
  .thesis > span {
    margin-bottom: 1.5rem;
    color: var(--color-copper);
    font-family: var(--font-data);
    font-size: var(--caption);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .thesis p {
    margin: 0;
    font-size: var(--step-1);
    line-height: 1.75;
  }
  .confidence {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 1rem;
    padding: 1.4rem 1.5rem;
    color: var(--color-olive);
    border-top: 1px solid var(--border-subtle);
  }
  .featured-empty,
  .section-empty {
    padding: clamp(3rem, 8vw, 8rem) 1.5rem;
    border-bottom: 1px solid var(--border-subtle);
  }
  .featured-empty p,
  .section-empty p {
    margin: 0;
    color: var(--text-secondary);
    font-size: var(--step-1);
  }
  .investment-list,
  .compact-list {
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .investment-list li {
    display: grid;
    grid-template-columns: 4.5rem minmax(0, 1fr) auto;
    gap: 1.5rem;
    align-items: start;
    min-height: 270px;
    padding: 2.5rem 1.5rem;
    border-bottom: 1px solid var(--border-subtle);
  }
  .entry-index {
    padding-top: 0.25rem;
    color: var(--color-copper);
  }
  .entry-copy {
    max-width: 880px;
  }
  .entry-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 1.25rem;
    margin: 0 0 1rem;
    color: var(--color-olive);
  }
  .entry-copy h3 {
    max-width: 24ch;
    margin: 0;
    font-size: var(--step-3);
    font-weight: var(--weight-medium);
    letter-spacing: -0.025em;
    line-height: 1.14;
  }
  .entry-copy h3 a {
    transition: color var(--duration-fast) linear;
  }
  .entry-copy h3 a:hover {
    color: var(--color-copper);
  }
  .entry-summary {
    max-width: 760px;
    margin: 1.25rem 0 0;
    color: var(--text-secondary);
    line-height: 1.85;
  }
  .row-link {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    color: var(--color-copper);
    border-bottom: 1px solid currentColor;
  }
  .secondary-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    border-bottom: 1px solid var(--border-subtle);
  }
  .desk-module {
    display: grid;
    grid-template-rows: auto 1fr auto;
    min-height: 440px;
    padding: 0 1.5rem 1.5rem;
    border-right: 1px solid var(--border-subtle);
  }
  .desk-module:last-child {
    border-right: 0;
  }
  .module-heading {
    display: grid;
    grid-template-columns: 2rem 1fr;
    gap: 0.75rem;
    align-items: center;
    min-height: 72px;
    border-bottom: 1px solid var(--border-subtle);
  }
  .module-heading > span {
    color: var(--color-copper);
  }
  .module-heading h2 {
    margin: 0;
    font: inherit;
  }
  .module-empty {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 2.5rem 0;
  }
  .module-empty p {
    max-width: 34rem;
    margin: 0;
    color: var(--text-secondary);
    font-size: var(--step-1);
    line-height: 1.8;
  }
  .module-empty span {
    margin-top: 2rem;
    padding-top: 1rem;
    color: var(--color-olive);
    border-top: 1px solid var(--border-subtle);
  }
  .compact-list li {
    display: grid;
    gap: 0.6rem;
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--border-subtle);
  }
  .compact-list time {
    color: var(--color-olive);
  }
  .compact-list a {
    font-size: var(--step-1);
    line-height: 1.4;
    transition: color var(--duration-fast) linear;
  }
  .compact-list a:hover {
    color: var(--color-copper);
  }
  .module-link {
    display: inline-flex;
    align-items: center;
    justify-content: space-between;
    min-height: 48px;
    margin-top: 1.5rem;
    color: var(--color-copper);
    border-bottom: 1px solid currentColor;
    transition: color var(--duration-fast) linear;
  }
  .module-link:hover {
    color: var(--text-primary);
  }
  .method {
    display: grid;
    grid-template-columns: 0.65fr 1.35fr;
    min-height: 430px;
