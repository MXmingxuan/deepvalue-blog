---
import Base from '../../layouts/Base.astro';
import { getPublishedEntries } from '../../lib/entries.mjs';

const keywords = ['油运', '干散货', '集装箱', '造船', '船用发动机', '海工装备'];
const posts = await getPublishedEntries();

const topicPosts = posts
  .filter(post => post.data.domain === 'investment' && post.data.topic === 'shipping');
---

<Base title="航运与船舶研究 - Deep Value Research" description="航运、船舶、造船与船舶周期研究">
  <section class="topic-hero shipping">
    <p class="eyebrow">SHIPPING & SHIPBUILDING</p>
    <h1>航运与船舶研究</h1>
    <p>
      同时覆盖航运周期与船舶制造：运价、船队供需、订单、拆船、造船产能、船用设备和海工装备。这里先放好研究入口，后续文章会自动归档到这个专题。
    </p>
  </section>

  <section class="research-list">
    <div class="list-header">
      <span>{topicPosts.length} 篇相关文章</span>
      <span>当前重点：{keywords.join(' / ')}</span>
    </div>
    {topicPosts.length > 0 ? (
      topicPosts.map(post => (
        <article class="research-item">
          <a href={`/blog/${post.data.publish_id}`}>{post.data.title}</a>
          <div class="meta">
            <span>{post.data.published_at.toLocaleDateString('zh-CN')}</span>
            <span>{post.data.format}</span>
            {post.data.tags.slice(0, 3).map(tag => <span class="tag">{tag}</span>)}
          </div>
          {post.data.summary && <p>{post.data.summary}</p>}
        </article>
      ))
    ) : (
      <p class="empty-state">船舶与航运研究文章还没开始写，这里先作为专题入口占位。</p>
    )}
  </section>
</Base>

<style>
  .topic-hero {
    padding: 78px 0 64px;
    border-bottom: 1px solid rgba(216, 181, 109, 0.52);
  }

  .eyebrow {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    color: var(--muted);
  }

  h1 {
    max-width: 900px;
    margin-top: 18px;
    font-size: clamp(52px, 8vw, 104px);
    font-weight: 500;
    line-height: 0.96;
    letter-spacing: 0;
  }

  .topic-hero p:last-child {
    max-width: 780px;
    margin-top: 28px;
    font-size: 20px;
    line-height: 1.8;
    color: rgba(246, 243, 236, 0.76);
  }

  .research-list {
    padding: 56px 0 0;
  }

  .list-header {
    display: flex;
    justify-content: space-between;
    gap: 20px;
    flex-wrap: wrap;
    padding-bottom: 22px;
    border-bottom: 1px solid var(--line);
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.06em;
    color: var(--muted);
  }

  .research-item {
    display: grid;
    gap: 14px;
    padding: 30px 0;
    border-bottom: 1px solid var(--line);
  }

  .research-item a {
    font-size: clamp(24px, 4vw, 44px);
    line-height: 1.12;
  }

  .research-item p,
  .empty-state {
    max-width: 720px;
    color: rgba(246, 243, 236, 0.72);
  }

  .empty-state {
    padding: 40px 0;
  }

  .meta {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--muted);
  }
</style>
