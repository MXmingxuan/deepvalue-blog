---
import Base from '../../layouts/Base.astro';
import EntryList from '../../components/EntryList.astro';
import { getPublishedEntries } from '../../lib/entries.mjs';

const entries = await getPublishedEntries({ domain: 'beyond' });

const sections = [
  { href: '/beyond/', label: '全部' },
  { href: '/beyond/?section=life', label: '生活观察' },
  { href: '/beyond/?section=reading', label: '阅读与思考' },
  { href: '/beyond/?section=projects', label: '个人项目' },
  { href: '/beyond/?section=other', label: '其他探索' },
];
---

<Base title="边界之外 - Deep Value Research" description="生活、阅读、个人项目与其他边界探索">
  <header class="publication-header">
    <div class="publication-kicker">
      <p>BEYOND THE BOUNDARY</p>
      <span>03 / LOWER EMPHASIS</span>
    </div>
    <div class="publication-copy">
      <h1>边界之外</h1>
      <p class="publication-description">
        收录不以投资或 AI 为主要对象的生活观察、阅读思考、个人项目与其他兴趣，保留专业研究之外的必要余地。
      </p>
    </div>
  </header>

  <nav class="section-index" data-section-index aria-label="边界之外栏目">
    <p>SECTION INDEX</p>
    <ol>
      {sections.map(section => (
        <li><a href={section.href}>{section.label}</a></li>
      ))}
    </ol>
  </nav>

  <aside class="project-directory" aria-labelledby="project-directory-title">
    <div>
      <p>PROJECTS &amp; TOOLS</p>
      <h2 id="project-directory-title">项目与工具</h2>
      <span>独立浏览投资分析工具、交易研究系统与 AI 应用实践。</span>
    </div>
    <a href="/projects/">进入项目目录 <span aria-hidden="true">→</span></a>
  </aside>

  <EntryList
    entries={entries}
    emptyText="边界之外暂时没有已发布内容；相关记录会在发布后出现在这里。"
    groupByFormat
  />
</Base>

<style>
  .project-directory {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: end;
    gap: var(--space-4);
    margin: var(--space-5) 0 var(--space-6);
    padding: var(--space-4);
    color: var(--text-inverse);
    background: var(--surface-inverse);
    border-top: 3px solid var(--color-copper-on-ink);
  }

  .project-directory div {
    display: grid;
    gap: var(--space-1);
  }

  .project-directory p,
  .project-directory h2,
  .project-directory span {
    margin: 0;
  }

  .project-directory p,
  .project-directory a {
    font-family: var(--font-data);
    font-size: var(--caption);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .project-directory p,
  .project-directory a {
    color: var(--color-copper-on-ink);
  }

  .project-directory h2 {
    font-size: var(--step-2);
    font-weight: var(--weight-medium);
  }

  .project-directory div > span {
    color: var(--text-inverse-muted);
  }

  .project-directory a {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    padding-bottom: 0.25rem;
    border-bottom: 1px solid currentColor;
  }

  .project-directory a:hover {
    color: var(--text-inverse);
  }

  @media (max-width: 640px) {
    .project-directory {
      grid-template-columns: 1fr;
      align-items: start;
    }

    .project-directory a {
      justify-self: start;
    }
  }
</style>
