---
import '@fontsource/bebas-neue/400.css';
import '@fontsource/space-mono/400.css';
import '@fontsource/space-mono/700.css';
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description || 'Deep Value'} />
    <title>{title}</title>
    <style>
      /* Bugatti-style global reset */
      html {
        scroll-behavior: smooth;
      }
    </style>
  </head>
  <body>
    <header>
      <div class="wordmark">DEEP VALUE</div>
      <div class="nav-divider"></div>
      <nav>
        <a href="/" class="nav-link">首页</a>
        <a href="/projects" class="nav-link">项目</a>
        <a href="/blog" class="nav-link">博客</a>
        <a href="/ai-industry-chain/" class="nav-link">产业链</a>
        <a href="/futures-analysis/" class="nav-link">期货分析</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <div class="footer-links">
        <a href="https://github.com/MXmingxuan" target="_blank" class="footer-link">GITHUB</a>
        <a href="https://x.com/mingxuan808" target="_blank" class="footer-link">X</a>
        <span class="footer-text">mingxuantrading@foxmail.com</span>
      </div>
      <p class="copyright">© 2026 宋明璇</p>
    </footer>
  </body>
</html>

<style>
  :root {
    /* Bugatti Color Palette */
    --velvet-black: #000000;
    --showroom-white: #ffffff;
    --silver-mist: #999999;

    /* Semantic mappings */
    --color-bg: var(--velvet-black);
    --color-surface: var(--velvet-black);
    --color-border: var(--silver-mist);
    --color-primary: var(--showroom-white);
    --color-text: var(--showroom-white);
    --color-text-dim: var(--silver-mist);

    /* Typography */
    --font-display: "Bebas Neue", "Impact", ui-sans-serif, sans-serif;
    --font-mono: "Space Mono", "SF Mono", "Fira Code", monospace;
    --font-body: "Inter", "PingFang SC", "Microsoft YaHei", ui-sans-serif, sans-serif;
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  body {
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.6;
    color: var(--color-text);
    background: var(--color-bg);
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
  }

  main {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 48px;
  }

  header {
    max-width: 1200px;
    margin: 0 auto;
    padding: 48px 48px 32px;
  }

  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .wordmark {
    font-family: var(--font-display);
    font-size: 48px;
    letter-spacing: 0.15em;
    color: var(--showroom-white);
    text-align: center;
    margin-bottom: 24px;
  }

  .nav-divider {
    width: 100%;
    height: 1px;
    background: var(--silver-mist);
    margin-bottom: 24px;
    opacity: 0.4;
  }

  nav {
    display: flex;
    justify-content: center;
    gap: 48px;
  }

  nav a.nav-link {
    font-family: var(--font-mono);
    font-size: 14px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--showroom-white);
    text-decoration: none;
    opacity: 0.85;
    transition: opacity 0.2s ease;
  }

  nav a.nav-link:hover {
    opacity: 1;
  }

  footer {
    max-width: 1200px;
    margin: 120px auto 0;
    padding: 64px 48px;
    border-top: 1px solid var(--silver-mist);
  }

  .footer-links {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 32px;
    margin-bottom: 24px;
  }

  a.footer-link {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--showroom-white);
    text-decoration: none;
    opacity: 0.6;
    transition: opacity 0.2s ease;
  }

  a.footer-link:hover {
    opacity: 1;
  }

  .footer-text {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.08em;
    color: var(--silver-mist);
  }

  .copyright {
    text-align: center;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    color: var(--silver-mist);
    text-transform: uppercase;
  }

  /* Typography */
  h1 {
    font-family: var(--font-display);
    font-size: 72px;
    font-weight: 400;
    line-height: 1;
    letter-spacing: 0.02em;
    color: var(--showroom-white);
  }

  h2 {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--silver-mist);
    margin-bottom: 24px;
  }

  a {
    color: var(--showroom-white);
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  a:hover {
    opacity: 0.7;
  }

  /* Pill Button */
  .pill-btn {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--showroom-white);
    background: transparent;
    border: 1px solid var(--showroom-white);
    border-radius: 9999px;
    padding: 14px 28px;
    text-decoration: none;
    transition: all 0.25s ease;
    cursor: pointer;
  }

  .pill-btn:hover {
    background: var(--showroom-white);
    color: var(--velvet-black);
    opacity: 1;
  }

  /* Tag style */
  .tag {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--silver-mist);
    border: 1px solid var(--silver-mist);
    border-radius: 9999px;
    padding: 4px 10px;
  }

  @media (max-width: 768px) {
    main {
      padding: 0 24px;
    }

    header {
      padding: 32px 24px 24px;
    }

    .wordmark {
      font-size: 18px;
      margin-bottom: 16px;
    }

    .nav-divider {
      margin-bottom: 16px;
    }

    nav {
      gap: 24px;
    }

    nav a.nav-link {
      font-size: 11px;
    }

    footer {
      padding: 48px 24px;
      margin-top: 80px;
    }

    .footer-links {
      flex-direction: column;
      gap: 16px;
    }
  }
</style>
