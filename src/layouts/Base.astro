---
import '@fontsource/bebas-neue/400.css';
import '@fontsource/space-mono/400.css';
import '@fontsource/space-mono/700.css';
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;

const navItems = [
  { href: '/investment/', label: '投资研究' },
  { href: '/ai/', label: 'AI 与技术' },
  { href: '/research-log/', label: '研究日志' },
  { href: '/beyond/', label: '边界之外' },
  { href: '/archive/', label: '档案' },
  { href: '/about/', label: '关于' },
];
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description || 'Deep Value Research'} />
    <title>{title}</title>
    <style>
      html {
        scroll-behavior: smooth;
      }
    </style>
  </head>
  <body>
    <header class="site-header">
      <a href="/" class="wordmark">DEEP VALUE RESEARCH</a>
      <nav aria-label="主导航">
        {navItems.map(item => (
          <a href={item.href} class="nav-link">{item.label}</a>
        ))}
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <div class="footer-inner">
        <span>RESEARCH ARCHIVE</span>
        <a href="https://github.com/MXmingxuan" target="_blank" rel="noreferrer">GITHUB</a>
        <a href="https://x.com/mingxuan808" target="_blank" rel="noreferrer">X</a>
        <span>mingxuantrading@foxmail.com</span>
      </div>
    </footer>
  </body>
</html>

<style>
  :root {
    --ink: #050505;
    --paper: #f5f3ee;
    --paper-soft: #ece8df;
    --line: rgba(245, 243, 238, 0.22);
    --muted: #a7a39a;
    --text: #f6f3ec;
    --accent-fluorine: #74d7b3;
    --accent-ai: #9eb8ff;
    --accent-warm: #d8b56d;
    --accent-energy: #f2c94c;

    --velvet-black: var(--ink);
    --showroom-white: var(--text);
    --silver-mist: var(--muted);
    --color-bg: var(--ink);
    --color-text: var(--text);
    --color-text-dim: var(--muted);

    --font-display: "Bebas Neue", "Impact", ui-sans-serif, sans-serif;
    --font-mono: "Space Mono", "SF Mono", "Fira Code", monospace;
    --font-body: "Inter", "PingFang SC", "Microsoft YaHei", ui-sans-serif, sans-serif;
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  body {
    min-height: 100vh;
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.6;
    color: var(--text);
    background:
      linear-gradient(90deg, rgba(245, 243, 238, 0.045) 1px, transparent 1px),
      linear-gradient(180deg, rgba(245, 243, 238, 0.032) 1px, transparent 1px),
      var(--ink);
    background-size: 72px 72px;
    -webkit-font-smoothing: antialiased;
  }

  body::before {
    content: "";
    position: fixed;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    background:
      linear-gradient(135deg, rgba(116, 215, 179, 0.12), transparent 30%),
      linear-gradient(315deg, rgba(158, 184, 255, 0.12), transparent 32%);
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  main,
  .site-header,
  footer {
    width: min(1180px, calc(100% - 48px));
    margin: 0 auto;
  }

  .site-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
    padding: 32px 0 28px;
    border-bottom: 1px solid var(--line);
  }

  .wordmark {
    font-family: var(--font-display);
    font-size: clamp(28px, 4vw, 48px);
    line-height: 0.9;
    letter-spacing: 0.08em;
  }

  nav {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 24px;
    flex-wrap: wrap;
  }

  .nav-link {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.08em;
    color: var(--muted);
    transition: color 0.2s ease;
  }

  .nav-link:hover {
    color: var(--text);
  }

  footer {
    margin-top: 96px;
    padding: 32px 0 48px;
    border-top: 1px solid var(--line);
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    flex-wrap: wrap;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    color: var(--muted);
  }

  .tag {
    display: inline-flex;
    align-items: center;
    min-height: 24px;
    padding: 3px 9px;
    border: 1px solid rgba(245, 243, 238, 0.22);
    border-radius: 999px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.04em;
    color: var(--muted);
  }

  .pill-btn {
    display: inline-flex;
    align-items: center;
    min-height: 42px;
    padding: 10px 18px;
    border: 1px solid rgba(245, 243, 238, 0.32);
    border-radius: 999px;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.08em;
    color: var(--text);
    transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease;
  }

  .pill-btn:hover {
    background: var(--text);
    border-color: var(--text);
    color: var(--ink);
  }

  @media (max-width: 760px) {
    main,
    .site-header,
    footer {
      width: min(100% - 32px, 1180px);
    }

    .site-header {
      align-items: flex-start;
      flex-direction: column;
      gap: 20px;
      padding-top: 24px;
    }

    nav {
      justify-content: flex-start;
      gap: 14px 18px;
    }

    .nav-link {
      font-size: 11px;
      letter-spacing: 0.04em;
    }

    footer {
      margin-top: 72px;
    }

    .footer-inner {
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>
