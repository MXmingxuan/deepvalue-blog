---
import '@fontsource/space-mono/400.css';
import '@fontsource/space-mono/700.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
const currentPath = Astro.url.pathname;
const isHome = currentPath === '/';

const navItems = [
  { href: '/investment/', label: '投资研究' },
  { href: '/ai/', label: 'AI 与技术' },
  { href: '/research-log/', label: '研究日志' },
  { href: '/beyond/', label: '边界之外' },
  { href: '/archive/', label: '档案' },
  { href: '/about/', label: '关于' },
];
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content={description || 'Deep Value 以投资、交易与大宗商品研究为核心。'}
    />
    <meta name="theme-color" content="#0b0c0b" />
    <title>{title}</title>
  </head>
  <body class:list={{ 'home-page': isHome }}>
    <a class="skip-link" href="#main-content">跳到主要内容</a>

    <header class="site-header">
      <div class="header-inner">
        <a href="/" class="wordmark" aria-label="Deep Value Research 首页">
          Deep Value Research
        </a>
        <span class="edition">Independent research publication</span>
        <nav aria-label="主导航">
          {navItems.map(item => (
            <a
              href={item.href}
              class="nav-link"
              aria-current={currentPath.startsWith(item.href) ? 'page' : undefined}
            >
              {item.label}
            </a>
          ))}
        </nav>
      </div>
    </header>

    <main id="main-content" tabindex="-1">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-inner">
        <p class="footer-wordmark">Deep Value</p>
        <div class="footer-meta">
          <span>Independent research publication</span>
          <span>Investment · Commodities · AI</span>
          <div class="footer-links">
            <a href="mailto:mingxuantrading@foxmail.com">Email</a>
            <a href="https://github.com/MXmingxuan" target="_blank" rel="noreferrer">GitHub</a>
            <a href="https://x.com/mingxuan808" target="_blank" rel="noreferrer">X</a>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    /* Canonical Deep Value production palette. */
    --color-ink: #0b0c0b;
    --color-paper: #d8cfbd;
    --color-copper: #a46743;
    --color-olive: #777b68;
    --color-chalk: #eee8dc;
    --color-smoke: #252620;

    --color-border-on-paper: color-mix(in srgb, var(--color-ink) 18%, var(--color-paper));
    --color-border-on-ink: color-mix(in srgb, var(--color-paper) 19%, var(--color-ink));
    --color-ink-muted: color-mix(in srgb, var(--color-ink) 68%, var(--color-paper));
    --color-paper-muted: color-mix(in srgb, var(--color-paper) 67%, var(--color-ink));
    --color-paper-deep: color-mix(in srgb, var(--color-paper) 90%, var(--color-ink));

    --font-editorial: "Songti SC", "STSong", "Noto Serif CJK SC", "Source Han Serif SC", Georgia, serif;
    --font-data: "Space Mono", "SFMono-Regular", Consolas, "Liberation Mono", monospace;
    --weight-regular: 400;
    --weight-medium: 500;
    --weight-bold: 700;

    --step--1: clamp(0.72rem, 0.7rem + 0.08vw, 0.8rem);
    --step-0: clamp(0.96rem, 0.91rem + 0.22vw, 1.1rem);
    --step-1: clamp(1.16rem, 1.06rem + 0.46vw, 1.44rem);
    --step-2: clamp(1.44rem, 1.24rem + 0.9vw, 2rem);
    --step-3: clamp(1.8rem, 1.39rem + 1.8vw, 2.9rem);
    --step-4: clamp(2.3rem, 1.55rem + 3.35vw, 4.35rem);
    --step-5: clamp(3.05rem, 1.65rem + 6.2vw, 6.85rem);

    --surface-primary: var(--color-paper);
    --surface-secondary: var(--color-paper-deep);
    --surface-inverse: var(--color-ink);
    --text-primary: var(--color-ink);
    --text-secondary: var(--color-ink-muted);
    --text-inverse: var(--color-paper);
    --text-inverse-muted: var(--color-paper-muted);
    --link-primary: var(--color-copper);
    --metadata-primary: var(--color-olive);
    --border-subtle: var(--color-border-on-paper);
    --border-subtle-inverse: var(--color-border-on-ink);

    --h1: var(--step-5);
    --h2: var(--step-4);
    --h3: var(--step-2);
    --body: var(--step-0);
    --body-large: var(--step-1);
    --caption: var(--step--1);

    --space-1: 0.375rem;
    --space-2: 0.75rem;
    --space-3: 1.125rem;
    --space-4: 1.75rem;
    --space-5: 2.75rem;
    --space-6: 4.5rem;
    --space-7: 7rem;
    --radius-editorial: 0;
    --radius-control: 2px;
    --duration-fast: 140ms;
    --duration-base: 280ms;
    --duration-entrance: 700ms;
    --ease-editorial: cubic-bezier(0.22, 1, 0.36, 1);
    --shadow-lift: 0 18px 48px color-mix(in srgb, var(--color-ink) 20%, transparent);
    --header-height: 73px;

    /* Transitional aliases keep existing published routes readable until their editorial pass. */
    --ink: var(--color-ink);
    --paper: var(--color-paper);
    --paper-soft: var(--surface-secondary);
    --line: var(--border-subtle);
    --muted: var(--text-secondary);
    --text: var(--text-primary);
    --velvet-black: var(--color-ink);
    --showroom-white: var(--color-paper);
    --silver-mist: var(--color-olive);
    --color-bg: var(--color-paper);
    --color-text: var(--color-ink);
    --color-text-dim: var(--text-secondary);
    --font-display: var(--font-editorial);
    --font-mono: var(--font-data);
    --font-body: var(--font-editorial);
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
    background: var(--surface-inverse);
  }

  body {
    min-width: 20rem;
    min-height: 100vh;
    margin: 0;
    color: var(--text-primary);
    background: var(--surface-primary);
    font-family: var(--font-editorial);
    font-size: var(--body);
    line-height: 1.7;
    text-rendering: optimizeLegibility;
    -webkit-font-smoothing: antialiased;
  }

  body.home-page {
    background: var(--surface-inverse);
  }

  ::selection {
    color: var(--color-chalk);
    background: var(--color-copper);
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  img,
  picture,
  video {
    display: block;
    max-width: 100%;
  }

  button,
  input,
  textarea,
  select {
    font: inherit;
  }

  a:focus-visible,
  button:focus-visible,
  input:focus-visible,
  textarea:focus-visible,
  select:focus-visible {
    outline: 2px solid var(--color-copper);
    outline-offset: 4px;
  }

  .skip-link {
    position: fixed;
    top: 0.75rem;
    left: 0.75rem;
    z-index: 100;
    min-height: 44px;
    padding: 0.7rem 1rem;
    color: var(--text-inverse);
    background: var(--color-ink);
    border: 1px solid var(--color-copper);
    border-radius: var(--radius-control);
    font-family: var(--font-data);
    font-size: var(--caption);
    transform: translateY(calc(-100% - 1rem));
    transition: transform var(--duration-fast) var(--ease-editorial);
  }

  .skip-link:focus {
    transform: translateY(0);
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    min-height: var(--header-height);
    color: var(--text-inverse);
    background: color-mix(in srgb, var(--color-ink) 92%, transparent);
    border-bottom: 1px solid var(--border-subtle-inverse);
    backdrop-filter: blur(12px);
  }

  .header-inner {
    display: grid;
    grid-template-columns: minmax(190px, 0.85fr) minmax(0, 1.15fr) auto;
    min-height: 72px;
    width: min(1440px, 100%);
    margin: 0 auto;
  }

  .wordmark,
  .edition,
  .site-header nav {
    display: flex;
    align-items: center;
  }

  .wordmark {
    min-height: 44px;
    padding: 0 3.2vw;
    border-right: 1px solid var(--border-subtle-inverse);
    font-family: var(--font-data);
    font-size: 0.76rem;
    font-weight: var(--weight-bold);
    letter-spacing: 0.18em;
    line-height: 1.3;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .edition {
    padding: 0 1.5rem;
    color: var(--text-inverse-muted);
    font-family: var(--font-data);
    font-size: var(--caption);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .site-header nav {
    justify-content: flex-end;
    padding-right: 3.2vw;
  }

  .nav-link {
    position: relative;
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    margin-left: 1.25rem;
    color: var(--text-inverse-muted);
    font-family: var(--font-data);
    font-size: 0.68rem;
    letter-spacing: 0.06em;
    white-space: nowrap;
    transition: color var(--duration-base) var(--ease-editorial);
  }

  .nav-link::after {
    position: absolute;
    right: 0;
    bottom: 7px;
    left: 0;
    height: 1px;
    content: "";
    background: var(--color-copper);
    transform: scaleX(0);
    transform-origin: right;
    transition: transform var(--duration-base) var(--ease-editorial);
  }

  .nav-link:hover,
  .nav-link:focus-visible,
  .nav-link[aria-current="page"] {
    color: var(--text-inverse);
  }

  .nav-link:hover::after,
  .nav-link:focus-visible::after,
  .nav-link[aria-current="page"]::after {
    transform: scaleX(1);
    transform-origin: left;
  }

  main {
    width: min(1180px, calc(100% - 3rem));
    min-height: 62vh;
    margin: 0 auto;
    padding: var(--space-6) 0 var(--space-7);
  }

  main:focus {
    outline: none;
  }

  .home-page main {
    width: 100%;
    max-width: none;
    min-height: 0;
    margin-top: calc(-1 * var(--header-height));
    padding: 0;
  }

  .page-header {
    display: grid;
    gap: var(--space-2);
    margin-bottom: var(--space-5);
    padding-bottom: var(--space-5);
    border-bottom: 1px solid var(--border-subtle);
  }

  .page-header p {
    margin: 0;
    color: var(--color-copper);
    font-family: var(--font-data);
    font-size: var(--caption);
    letter-spacing: 0.13em;
  }

  .page-header h1 {
    margin: 0;
    font-size: var(--h2);
    font-weight: var(--weight-medium);
    letter-spacing: -0.025em;
    line-height: 1.08;
  }

  .site-footer {
    color: var(--text-inverse);
    background: var(--surface-inverse);
    border-top: 1px solid var(--border-subtle-inverse);
  }

  .footer-inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: end;
    width: min(1440px, 100%);
    min-height: 250px;
    margin: 0 auto;
    padding: 4rem 3.2vw 2.4rem;
  }

  .footer-wordmark {
    margin: 0;
    font-size: clamp(2.6rem, 7vw, 7rem);
    font-weight: var(--weight-medium);
    letter-spacing: -0.04em;
    line-height: 0.9;
  }

  .footer-meta {
    display: grid;
    justify-items: end;
    color: var(--text-inverse-muted);
    font-family: var(--font-data);
    font-size: var(--caption);
    letter-spacing: 0.06em;
    line-height: 1.8;
    text-transform: uppercase;
  }

  .footer-links {
    display: flex;
    gap: 1rem;
    margin-top: 0.5rem;
  }

  .footer-links a {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    color: var(--color-copper);
    transition: color var(--duration-fast) linear;
  }

  .footer-links a:hover {
    color: var(--text-inverse);
  }

  @media (max-width: 1120px) {
    .header-inner {
      grid-template-columns: auto 1fr auto;
    }

    .edition {
      font-size: 0;
    }

    .edition::after {
      font-size: var(--caption);
      content: "Independent publication";
    }

    .nav-link {
      margin-left: 0.85rem;
      letter-spacing: 0.03em;
    }
  }

  @media (max-width: 860px) {
    :root {
      --header-height: 109px;
    }

    .header-inner {
      grid-template-rows: 56px 52px;
      grid-template-columns: 1fr auto;
      min-height: 108px;
    }

    .wordmark {
      padding: 0 1rem;
    }

    .edition {
      justify-content: flex-end;
      padding: 0 1rem;
      font-size: 0;
    }

    .edition::after {
      font-size: 0.65rem;
      content: "Independent";
    }

    .site-header nav {
      grid-row: 2;
      grid-column: 1 / -1;
      justify-content: flex-start;
      min-width: 0;
      padding: 0 0.55rem;
      overflow-x: auto;
      border-top: 1px solid var(--border-subtle-inverse);
      scrollbar-width: thin;
      scrollbar-color: var(--color-copper) transparent;
    }

    .nav-link {
      flex: 0 0 auto;
      justify-content: center;
      min-width: 44px;
      min-height: 48px;
      margin: 0;
      padding: 0 0.65rem;
    }

    .nav-link::after {
      right: 0.65rem;
      left: 0.65rem;
    }

    main {
      width: min(100% - 2rem, 1180px);
    }
  }

  @media (max-width: 560px) {
    .edition {
      display: none;
    }

    .header-inner {
      grid-template-columns: 1fr;
    }

    .footer-inner {
      grid-template-columns: 1fr;
      gap: 3rem;
      min-height: 300px;
      padding-right: 1rem;
      padding-left: 1rem;
    }

    .footer-meta {
      justify-items: start;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    html {
      scroll-behavior: auto;
    }

    *,
    *::before,
    *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      scroll-behavior: auto !important;
      transition-duration: 0.01ms !important;
    }
  }
</style>
