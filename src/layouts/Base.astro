---
interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description || 'Deep Value'} />
    <title>{title}</title>
  </head>
  <body>
    <header>
      <nav>
        <a href="/">首页</a>
        <a href="/projects">项目</a>
        <a href="/blog">博客</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <div class="footer-links">
        <a href="https://github.com/MXmingxuan" target="_blank">GitHub</a>
        <a href="https://x.com/mingxuan808" target="_blank">X</a>
        <span class="email">mingxuantrading@foxmail.com</span>
        <span class="wechat">公众号：待添加</span>
      </div>
      <p class="copyright">&copy; 2026 宋明璇</p>
    </footer>
  </body>
</html>

<style>
  :root {
    --color-bg: #0a0a0a;
    --color-surface: #1a1a1a;
    --color-border: #2a2a2a;
    --color-primary: #ffffff;
    --color-text: #e0e0e0;
    --color-text-dim: #808080;
    --color-accent: #22c55e;
    --color-accent-dim: #166534;
    --font-mono: "SF Mono", "Fira Code", "Consolas", monospace;
    --font-sans: "PingFang SC", "Microsoft YaHei", -apple-system, BlinkMacSystemFont, sans-serif;
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  body {
    font-family: var(--font-sans);
    font-size: 17px;
    line-height: 1.75;
    color: var(--color-text);
    background: var(--color-bg);
    min-height: 100vh;
  }

  main {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 24px;
  }

  header {
    max-width: 800px;
    margin: 0 auto;
    padding: 40px 24px 32px;
  }

  nav a {
    position: relative;
    margin-right: 28px;
    color: var(--color-text-dim);
    text-decoration: none;
    font-size: 16px;
    font-family: var(--font-mono);
    letter-spacing: 0.02em;
    transition: color 0.15s ease;
  }

  nav a::before {
    content: '→';
    position: absolute;
    left: -18px;
    opacity: 0;
    color: var(--color-accent);
    transition: opacity 0.15s ease;
  }

  nav a:hover {
    color: var(--color-primary);
  }

  nav a:hover::before {
    opacity: 1;
  }

  nav a:last-child {
    margin-right: 0;
  }

  footer {
    max-width: 800px;
    margin: 96px auto 0;
    padding: 40px 24px;
    border-top: 1px solid var(--color-border);
    text-align: center;
  }

  .footer-links {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 20px;
    margin-bottom: 12px;
    flex-wrap: wrap;
  }

  .footer-links a {
    color: var(--color-text-dim);
    text-decoration: none;
    font-size: 13px;
    font-family: var(--font-mono);
    transition: color 0.15s ease;
  }

  .footer-links a:hover {
    color: var(--color-accent);
  }

  .email, .wechat {
    color: var(--color-text-dim);
    font-size: 13px;
    font-family: var(--font-mono);
  }

  .copyright {
    color: var(--color-text-dim);
    font-size: 12px;
    font-family: var(--font-mono);
  }

  h1 {
    font-size: 2.25rem;
    font-weight: 600;
    color: var(--color-primary);
    line-height: 1.2;
    letter-spacing: -0.01em;
  }

  h2 {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-accent-dim);
    margin-bottom: 1rem;
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  a {
    color: var(--color-accent);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  @media (max-width: 768px) {
    main {
      padding: 0 16px;
    }

    header {
      padding: 32px 16px 24px;
    }

    h1 {
      font-size: 1.75rem;
    }
  }
</style>
